      "name": "Get All Users",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"status is 200\", function() {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"response time under 2 seconds\", function() {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "});\r",
              "\r",
              "pm.test(\"response is an array and not empty\", function() {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json).to.be.an(\"array\").that.is.not.empty;\r",
              "});\r",
              "\r",
              "pm.test(\"first user has id property\", function() {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json[0]).to.have.property(\"id\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
